# access-top
# Show the top N remote hosts from ./access.log, including reverse DNS hostname.
# Use --all to include rotated access.log files, including .gz files.
# Optionally filter to only log lines containing a given string.
# Use --combine to group resolved domains by last two parts (e.g. x.example.com)
# and unresolved IPs by first three octets (e.g. 192.168.0.x).
# Usage: ./access-top [--all] [--combine] [-n N | --top N] [filter_string]
# Example: ./access-top
# Example: ./access-top -n 50
# Example: ./access-top --all --combine
# Example: ./access-top "bot"
# Example: ./access-top --all -n 200 "/wp-login.php"

set -euo pipefail

ACCESS_LOG="./access.log"
USE_ALL=false
USE_COMBINE=false
TOP_N=100
FILTER_STRING=""
LOG_FILES=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --all)
            USE_ALL=true
            shift
            ;;
        --combine)
            USE_COMBINE=true
            shift
            ;;
        -n|--top)
            if [ "$#" -lt 2 ]; then
                echo "Error: $1 requires a number"
                exit 1
            fi
            TOP_N="$2"
            shift 2
            ;;
        *)
            if [ -n "$FILTER_STRING" ]; then
                echo "Usage: $0 [--all] [--combine] [-n N | --top N] [filter_string]"
                exit 1
            fi
            FILTER_STRING="$1"
            shift
            ;;
    esac
done

if ! [[ "$TOP_N" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: -n / --top must be a positive integer"
    exit 1
fi

resolve_log_files() {
    local match=""

    if [ "$USE_ALL" = true ]; then
        while IFS= read -r match; do
            [ -f "$match" ] && LOG_FILES+=("$match")
        done < <(compgen -G "./access.log*" | sort -V || true)

        if [ "${#LOG_FILES[@]}" -eq 0 ]; then
            echo "Error: no files matched ./access.log*"
            echo "Run this script from the directory containing the access logs."
            exit 1
        fi
    else
        if [ ! -f "$ACCESS_LOG" ]; then
            echo "Error: access log not found at $ACCESS_LOG"
            echo "Run this script from the directory containing access.log."
            exit 1
        fi

        LOG_FILES=("$ACCESS_LOG")
    fi
}

# Timeout in seconds for DNS lookups (avoid stalling on slow/unresponsive resolvers)
DNS_TIMEOUT=2

resolve_hostname() {
    local ip="$1"
    local host_name=""
    local run=""
    local out=""
    local exit_status=0

    if command -v timeout >/dev/null 2>&1; then
        run() { timeout "$DNS_TIMEOUT" "$@"; }
    else
        run() { "$@"; }
    fi

    if command -v host >/dev/null 2>&1; then
        out=$(run host "$ip" 2>/dev/null)
        exit_status=$?
        if [ "$exit_status" -eq 124 ]; then
            host_name="-TIMEOUT-"
        else
            host_name=$(echo "$out" | awk -F' pointer ' '/domain name pointer/ {sub(/\.$/, "", $2); print $2; exit}')
        fi
    fi

    if [ -z "$host_name" ] && command -v dig >/dev/null 2>&1; then
        out=$(run dig +short -x "$ip" 2>/dev/null)
        exit_status=$?
        if [ "$exit_status" -eq 124 ]; then
            host_name="-TIMEOUT-"
        else
            host_name=$(echo "$out" | awk 'NF {sub(/\.$/, "", $0); print; exit}')
        fi
    fi

    if [ -z "$host_name" ]; then
        host_name="-"
    fi

    echo "$host_name"
}

resolve_log_files

printf "%6s %-20s %s\n" "COUNT" "REMOTE IP" "HOSTNAME"
printf "%6s %-20s %s\n" "-----" "---------" "--------"

if [ "$USE_COMBINE" = true ]; then
    TMP_COMBINE=$(mktemp)
    TMP_STDERR=$(mktemp)
    # Run pipeline first; set trap after so the pipeline's subshell doesn't inherit it.
    set +e
    zcat -f -- "${LOG_FILES[@]}" 2>"$TMP_STDERR" \
        | awk -v filter="$FILTER_STRING" '
            filter == "" || index($0, filter) > 0 {
                print $1
            }
        ' \
        | sort \
        | uniq -c \
        | sort -nr \
        | head -n "$TOP_N" \
        | while read -r count ip; do
            [ -n "${ip:-}" ] || continue
            printf "%s\t%s\t%s\n" "$count" "$ip" "$(resolve_hostname "$ip")"
        done > "$TMP_COMBINE"
    pipe_exit=$?
    set -e
    trap 'rm -f "$TMP_COMBINE" "$TMP_STDERR"' EXIT
    # Exit 141 (SIGPIPE) is normal when head closes the pipe after TOP_N lines; we still got the data.
    if [ "$pipe_exit" -ne 0 ] && [ "$pipe_exit" -ne 141 ]; then
        echo "Error: failed to process log files (exit $pipe_exit)." >&2
        [ -s "$TMP_STDERR" ] && cat "$TMP_STDERR" >&2
        exit 1
    fi
    if [ ! -s "$TMP_COMBINE" ]; then
        echo "Error: no log entries found." >&2
        exit 1
    fi

    # Combine only when multiple entries share the same key; singles show full IP and hostname.
    # Combined domain groups: show NA for IP, combined label (x.example.com) for hostname.
    # Combined IP groups: show combined label (192.168.0.x) for IP, NA for hostname.
    cat "$TMP_COMBINE" | awk -F'\t' '
        NF >= 2 {
            count = $1 + 0
            ip = $2
            hostname = (NF >= 3) ? $3 : "-"
            if (hostname == "-" || hostname == "-TIMEOUT-") {
                if (match(ip, /^[0-9]+\.[0-9]+\.[0-9]+/)) {
                    key = substr(ip, RSTART, RLENGTH) ".x"
                    is_domain_key = 0
                } else {
                    key = ip
                    is_domain_key = 0
                }
            } else {
                n = split(hostname, a, ".")
                if (n >= 2) {
                    key = "x." a[n-1] "." a[n]
                    is_domain_key = 1
                } else {
                    key = hostname
                    is_domain_key = 1
                }
            }
            sum[key] += count
            n_sources[key]++
            if (n_sources[key] == 1) {
                first_ip[key] = ip
                first_host[key] = hostname
                key_is_domain[key] = is_domain_key
            }
        }
        END {
            for (k in sum) {
                if (n_sources[k] > 1) {
                    if (key_is_domain[k]) {
                        print sum[k] "\tNA\t" k
                    } else {
                        print sum[k] "\t" k "\tNA"
                    }
                } else {
                    print sum[k] "\t" first_ip[k] "\t" first_host[k]
                }
            }
        }
    ' | sort -nr -k1,1 | while IFS=$'\t' read -r count ip_col host_col; do
        printf "%6s %-20s %s\n" "$count" "${ip_col:-}" "${host_col:-}"
    done
else
    zcat -f -- "${LOG_FILES[@]}" \
        | awk -v filter="$FILTER_STRING" '
            filter == "" || index($0, filter) > 0 {
                print $1
            }
        ' \
        | sort \
        | uniq -c \
        | sort -nr \
        | head -n "$TOP_N" \
        | while read -r count ip; do
            [ -n "${ip:-}" ] || continue
            printf "%6s %-20s %s\n" "$count" "$ip" "$(resolve_hostname "$ip")"
        done
fi
